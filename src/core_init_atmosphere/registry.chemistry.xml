<!-- **************************************************************************************** -->
<!-- ************************************** Dimensions ************************************** -->
<!-- **************************************************************************************** -->

        <dims>
           <dim name="nChem"              definition="namelist:num_chem"
               description="Number of chemical tracers (nscalar minus nmoist)"/>
           <dim name="nkanthro"             definition="namelist:kanthro"
               description="Number of vertical levels in anthropogenic emission file"/>
           <dim name="nkwildfire"             definition="namelist:kwildfire"
               description="Number of vertical levels in biomass burning emission file"/>
           <dim name="nkbiogenic"             definition="namelist:kbiogenic"
               description="Number of vertical levels in biogenic emission file"/>
           <dim name="nkvolcanic"             definition="namelist:kvolcanic"
               description="Number of vertical levels in volcanic emission file"/>
        </dims>


<!-- **************************************************************************************** -->
<!-- ************************************** Namelists *************************************** -->
<!-- **************************************************************************************** -->

   <nml_record name="chemistry" in_defaults="true">
      <nml_option name="config_smoke_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas smoke model"
           possible_values="`on',`off'"/>
      <nml_option name="config_pollen_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas pollen model"
           possible_values="`on',`off'"/>
      <nml_option name="config_dust_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas dust model"
           possible_values="`on',`off'"/>
      <nml_option name="config_ssalt_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas sea salt model"
           possible_values="`on',`off'"/>
      <nml_option name="config_anthro_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas anthropogenic emissions model"
           possible_values="`on',`off'"/>
      <nml_option name="config_volc_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas volcanic emissions model"
           possible_values="`on',`off'"/>
      <nml_option name="config_sna_scheme" type="character" default_value="off" in_defaults="false"
           units="-"
           description="configuration for mpas sulfate nitrate ammonium model"
           possible_values="`on',`off'"/>
      <nml_option name="config_coarse" type="logical" default_value="false" in_defaults="false"
           units="-"
           description="Logical flag to turn on/off coarse aerosols"
           possible_values=".true. or .false."/>
      <nml_option name="num_chem" type="integer" default_value="0"
           units="-"
           description="Number of chemical tracers"
           possible_values="Positive integer values"/>
      <nml_option name="kanthro" type="integer" default_value="1"
           units="-"
           description="Number of vertical levels in anthropogenic emission input"
           possible_values="Positive integer values"/>
      <nml_option name="kwildfire" type="integer" default_value="1"
           units="-"
           description="Number of vertical levels in biomaass burning emission input"
           possible_values="Positive integer values"/>
      <nml_option name="kbiogenic" type="integer" default_value="1"
           units="-"
           description="Number of vertical levels in biogenic emission input"
           possible_values="Positive integer values"/>
      <nml_option name="kvolcanic" type="integer" default_value="1"
           units="-"
           description="Number of vertical levels in volcanic emission input"
           possible_values="Positive integer values"/>
      <nml_option name="hwp_method" type="integer" default_value="1"
           units="-"
           description="Algorithm choice for the hourly wildfire potential"
           possible_values="Positive integer values"/>
      <nml_option name="ebb_dcycle" type="integer" default_value="0"
           units="-"
           description="Algorithm choice wildfire emission forecast"
           possible_values="Positive integer values"/>
   </nml_record>

<!-- **************************************************************************************** -->
<!-- **************************************  Packages  ************************************** -->
<!-- **************************************************************************************** -->
        <packages>
         <package name="mpas_smoke_in"  description="parameterization of smoke."/>
         <package name="speciated_pollen_rupture" description="parameterization of speciated rupture for pollen"/>
         <package name="speciated_pollen_primary" description="parameterization of speciated primary pollen"/>
         <package name="simple_pollen" description="parameterization of speciated primary pollen"/>
         <package name="mpas_dust_in"   description="parameterization of dust"/>
         <package name="mpas_ssalt_in"  description="parameterization of sea salt"/>
         <package name="mpas_anthro_in" description="parameterization of anthropogenic emissions for mpas-smoke"/>
         <package name="mpas_volc_in"   description="parameterization of volcanic emissions for mpas-smoke"/>
         <package name="mpas_sna_in"    description="parameterization of sulfate-nitrate-ammonium"/>
         <package name="mpas_aerosols_in" description="parameterization of mpas aerosols"/>
        </packages>


<!-- **************************************************************************************** -->
<!-- ************************************** Variables *************************************** -->
<!-- **************************************************************************************** -->

        <var_struct name="state" time_levs="1">
                <var_array name="scalars" type="real" dimensions="nVertLevels nCells Time" packages="met_stage_out">

                      <var name="smoke_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine smoke mixing ratio"
                           packages="mpas_smoke_in"/>

                      <var name="smoke_coarse" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse smoke mixing ratio"
                           packages="mpas_smoke_in"/>

                      <var name="polp_tree" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse tree pollen mixing ratio"
                           packages="speciated_pollen_primary;speciated_pollen_rupture"/>
       
                      <var name="polp_grass" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse grass pollen mixing ratio"
                           packages="speciated_pollen_primary;speciated_pollen_rupture"/>
       
                      <var name="polp_weed" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse weed pollen mixing ratio"
                           packages="speciated_pollen_primary;speciated_pollen_rupture"/>
                      
                      <var name="polp_all" array_group="chemistry" units="kg kg^{-1}"
                           description="combined primary pollen mixing ratio"
                           packages="simple_pollen"/>
      
                      <var name="pols_all" array_group="chemistry" units="kg kg^{-1}"
                           description="combined ruptured pollen mixing ratio"
                           packages="simple_pollen;speciated_pollen_primary"/>
       
                      <var name="pols_tree" array_group="chemistry" units="kg kg^{-1}"
                           description="fine tree pollen mixing ratio"
                           packages="speciated_pollen_rupture"/>
       
                      <var name="pols_grass" array_group="chemistry" units="kg kg^{-1}"
                           description="fine grass pollen mixing ratio"
                           packages="speciated_pollen_rupture"/>
       
                      <var name="pols_weed" array_group="chemistry" units="kg kg^{-1}"
                           description="fine weed pollen mixing ratio"
                           packages="speciated_pollen_rupture"/>
 
                      <var name="dust_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine dust mixing ratio"
                           packages="mpas_dust_in;mpas_anthro_in"/>

                      <var name="dust_coarse" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse dust mixing ratio"
                           packages="mpas_dust_in;mpas_anthro_in"/>
 
                      <var name="ssalt_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine sea salt mixing ratio"
                           packages="mpas_ssalt_in"/>
 
                      <var name="ssalt_coarse" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse sea salt mixing ratio"
                           packages="mpas_ssalt_in"/>

                      <var name="unspc_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine anthropogenic primary aerosol mixing ration"
                           packages="mpas_anthro_in"/>
 
                      <var name="unspc_coarse" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse anthropogenic primary aerosol"
                           packages="mpas_anthro_in"/>

                      <var name="vash_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine volcanic ash"
                           packages="mpas_volc_in"/> 

                      <var name="vash_coarse" array_group="chemistry" units="kg kg^{-1}"
                           description="coarse volcanic ash"
                           packages="mpas_volc_in"/> 

                      <var name="so4_a_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine sulfate aerosol"
                           packages="mpas_aerosols_in;mpas_sna_in"/>
 
                      <var name="no3_a_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine nitrate aerosol"
                           packages="mpas_aerosols_in;mpas_sna_in"/> 

                      <var name="nh4_a_fine" array_group="chemistry" units="kg kg^{-1}"
                           description="fine ammonium aerosol"
                           packages="mpas_aerosols_in;mpas_sna_in"/> 

                      <var name="so2" array_group="chemistry" units="mol mol^{-1}"
                           description="sulfur dioxide"
                           packages="mpas_aerosols_in;mpas_sna_in"/> 

                      <var name="nh3" array_group="chemistry" units="mol mol^{-1}"
                           description="ammonia"
                           packages="mpas_aerosols_in;mpas_sna_in"/> 
                </var_array>
        </var_struct>

        <var_struct name="lbc_state" time_levs="1">
                <var_array name="lbc_scalars" type="real" dimensions="nVertLevels nCells Time" packages="lbcs">
                        <var name="lbc_smoke_fine" array_group="chemistry"  packages="mpas_smoke_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine smoke mixing ratio"/>

                        <var name="lbc_smoke_coarse" array_group="chemistry"  packages="mpas_smoke_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse smoke mixing ratio"/>
                        
                        <var name="lbc_polp_tree" array_group="chemistry"  packages="speciated_pollen_primary;speciated_pollen_rupture" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse tree pollen mixing ratio"/>
  
                        <var name="lbc_polp_grass" array_group="chemistry"  packages="speciated_pollen_primary;speciated_pollen_rupture" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse grass pollen mixing ratio"/>
  
                        <var name="lbc_polp_weed" array_group="chemistry"  packages="speciated_pollen_primary;speciated_pollen_rupture" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse weed pollen mixing ratio"/>

                        <var name="lbc_polp_all" array_group="chemistry"  packages="simple_pollen" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of total primary pollen mixing ratio"/>
                        
                        <var name="lbc_pols_all" array_group="chemistry"  packages="simple_pollen;speciated_pollen_primary" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of total fine pollen mixing ratio"/>
  
                        <var name="lbc_pols_tree" array_group="chemistry"  packages="speciated_pollen_rupture" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine tree pollen mixing ratio"/>
  
                        <var name="lbc_pols_grass" array_group="chemistry"  packages="speciated_pollen_rupture" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine grass pollen mixing ratio"/>
  
                        <var name="lbc_pols_weed" array_group="chemistry"  packages="speciated_pollen_rupture" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine weed pollen mixing ratio"/>
  
                        <var name="lbc_dust_fine" array_group="chemistry"  packages="mpas_dust_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine dust mixing ratio"/>

                        <var name="lbc_dust_coarse" array_group="chemistry"  packages="mpas_dust_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse dust mixing ratio"/>
  
                        <var name="lbc_ssalt_fine" array_group="chemistry"  packages="mpas_ssalt_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine dust mixing ratio"/>
  
                        <var name="lbc_ssalt_coarse" array_group="chemistry"  packages="mpas_ssalt_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse dust mixing ratio"/>
  
                        <var name="lbc_unspc_fine" array_group="chemistry"  packages="mpas_anthro_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of fine primary aerosol mixing ratio"/>
  
                        <var name="lbc_unspc_coarse" array_group="chemistry"  packages="mpas_anthro_in" units="kg kg^{-1} s^{-1}"
                             description="Lateral boundary tendency of coarse primary aerosol mixing ratio"/>

                </var_array>

        </var_struct>

        <var_struct name="fg" time_levs="1">
                <var name="smoke_fine_fg" name_in_code="smoke_fine" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_smoke_in;mpas_anthro_in" description="First guess fine smoke aerosols"/>
                <var name="dust_fine_fg" name_in_code="dust_fine" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_dust_in;mpas_anthro_in" description="First guess fine dust aerosols"/>
                <var name="dust_coarse_fg" name_in_code="dust_coarse" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_dust_in;mpas_anthro_in" description="First guess coarse dust aerosols"/>
                <var name="unspc_fine_fg" name_in_code="unspc_fine" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_anthro_in" description="First guess fine unspeciated aerosols"/>
                <var name="unspc_coarse_fg" name_in_code="unspc_coarse" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_anthro_in" description="First guess coarse unspeciaated aerosols"/>
                <var name="ssalt_fine_fg" name_in_code="ssalt_fine" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_ssalt_in" description="First guess fine sea salt aerosols"/>
                <var name="ssalt_coarse_fg" name_in_code="ssalt_coarse" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="mpas_ssalt_in" description="First guess coarse sea salt aerosols"/>
                <var name="polp_all_fg" name_in_code="polp_all" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="simple_pollen" description="First guess coarse pollen"/>
                <var name="pols_all_fg" name_in_code="polp_all" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="simple_pollen;speciated_pollen_rupture" description="First guess ruptured pollen"/>
                <var name="polp_tree_fg" name_in_code="polp_tree" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="speciated_pollen_primary;speciated_pollen_rupture" description="First guess coarse tree pollen"/>
                <var name="polp_grass_fg" name_in_code="polp_grass" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="speciated_pollen_primary;speciated_pollen_rupture" description="First guess coarse grass pollen"/>
                <var name="polp_weed_fg" name_in_code="polp_weed" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="speciated_pollen_primary;speciated_pollen_rupture" description="First guess coarse weed pollen"/>
                <var name="pols_tree_fg" name_in_code="pols_tree" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="speciated_pollen_rupture" description="First guess fine tree pollen"/>
                <var name="pols_grass_fg" name_in_code="pols_grass" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="speciated_pollen_rupture" description="First guess fine grass pollen"/>
                <var name="pols_weed_fg" name_in_code="pols_weed" type="real" dimensions="nFGLevels nCells Time" units="kg^{-1}"
		     packages="speciated_pollen_rupture" description="First guess fine weed pollen"/>

        </var_struct>
